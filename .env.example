# Database — PostgreSQL connection string (compose internal)
DATABASE_URL=postgresql+asyncpg://bitly:bitly@db:5432/bitly

# Redis — connection string (compose internal)
REDIS_URL=redis://redis:6379/0

# Rate limiting — max requests per IP per window
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_S=1

# Server — host port mapping (change APP_PORT to avoid host port conflicts)
APP_PORT=8010
APP_HOST=0.0.0.0
